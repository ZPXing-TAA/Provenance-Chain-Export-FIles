<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <title>{{ title }}</title>
  {% include "_common_css.html.j2" %}
  <style>
    .page {
      display: grid;
      grid-template-columns: minmax(320px, 460px) 1fr;
      gap: 24px;
      align-items: stretch;
    }
    .phone {
      border-radius: 32px;
      padding: 18px;
      background: var(--ink);
      box-shadow: var(--shadow);
      min-height: 0;
    }
    .screen {
      height: 100%;
      border-radius: 22px;
      background: var(--panel);
      overflow: hidden;
      display: grid;
      grid-template-rows: auto 1fr;
    }
    .topbar {
      padding: 18px;
      border-bottom: 1px solid var(--line);
    }
    .messages {
      padding: 18px;
      display: flex;
      flex-direction: column;
      gap: 12px;
      overflow: hidden;
    }
    .bubble {
      max-width: 82%;
      border-radius: 18px;
      padding: 12px 14px;
      background: color-mix(in srgb, var(--accent2), white 60%);
      color: var(--ink);
      font-size: 14px;
    }
    .bubble.right {
      align-self: flex-end;
      background: var(--accent);
      color: white;
    }
    .side {
      display: grid;
      grid-template-rows: auto 1fr;
      gap: 20px;
    }
    h1 {
      margin: 0;
      font-size: {{ typography.title_size }}px;
      line-height: 1;
    }
    .cards {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
    }
    .social-card {
      padding: 22px;
    }
    .value {
      color: var(--accent);
      font-size: 40px;
      font-weight: 900;
    }
  </style>
</head>
<body class="{{ body_class }}">
  <main class="page">
    <section class="phone">
      <div class="screen">
        <div class="topbar">
          <strong>{{ title }}</strong><br>
          <span class="muted">{{ subtitle }}</span>
        </div>
        <div class="messages">
          {% for message in messages %}
          <div class="bubble {{ message.side }}">
            <strong>{{ message.sender }}</strong><br>
            {{ message.text }}<br>
            <span style="opacity: .68;">{{ message.time }}</span>
          </div>
          {% endfor %}
        </div>
      </div>
    </section>
    <section class="side">
      <header>
        <div class="smallcaps">{{ org }}</div>
        <h1>{{ title }}</h1>
        <p class="muted">{{ subtitle }}</p>
      </header>
      <div class="cards">
        {% for card in social_cards %}
        <div class="card social-card">
          <div class="smallcaps">{{ card.label }}</div>
          <div class="value">{{ card.value }}</div>
        </div>
        {% endfor %}
      </div>
      <div class="card" style="padding: 24px;">{{ icons[2] | safe }}</div>
    </section>
  </main>
</body>
</html>
