<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <title>{{ title }}</title>
  {% include "_common_css.html.j2" %}
  <style>
    .page {
      padding: 0;
      display: grid;
      grid-template-rows: 1fr auto;
      background: {{ palette.accent }};
    }
    .poster {
      margin: {{ layout.margin }}px;
      border-radius: 8px;
      background: var(--panel);
      padding: 42px;
      display: grid;
      grid-template-rows: auto 1fr auto;
      gap: 28px;
    }
    h1 {
      margin: 0;
      font-size: {{ typography.title_size }}px;
      line-height: 0.98;
      letter-spacing: 0;
      max-width: 820px;
    }
    .tagline {
      margin-top: 18px;
      font-size: 25px;
      line-height: 1.3;
      color: var(--muted);
      max-width: 760px;
    }
    .middle {
      display: grid;
      grid-template-columns: 0.9fr 1.1fr;
      gap: 24px;
      align-items: stretch;
    }
    .date {
      background: var(--ink);
      color: white;
      border-radius: 8px;
      padding: 28px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }
    .date .day {
      font-size: 96px;
      line-height: 0.9;
      font-weight: 900;
    }
    .date .month {
      font-size: 28px;
      font-weight: 700;
    }
    .details {
      display: grid;
      gap: 14px;
    }
    .detail {
      border: 1px solid var(--line);
      border-radius: 8px;
      padding: 20px;
      font-size: 20px;
    }
    .chart-panel {
      border-top: 1px solid var(--line);
      padding-top: 20px;
    }
    .footer {
      padding: 0 {{ layout.margin }}px {{ layout.margin }}px;
      color: rgba(255, 255, 255, 0.88);
      display: flex;
      justify-content: space-between;
      font-size: 15px;
    }
  </style>
</head>
<body>
  <main class="page">
    <section class="poster">
      <header>
        <div class="smallcaps">{{ org }}</div>
        <h1>{{ title }}</h1>
        <div class="tagline">{{ tagline }}</div>
      </header>
      <section class="middle">
        <div class="date">
          <div>
            <div class="day">{{ day }}</div>
            <div class="month">{{ month }}</div>
          </div>
          <div>{{ city }} / {{ department }}</div>
        </div>
        <div class="details">
          {% for item in details %}
          <div class="detail">{{ item }}</div>
          {% endfor %}
        </div>
      </section>
      <section class="chart-panel">
        <div class="smallcaps">{{ chart_title }}</div>
        <div class="chart">{{ chart_svg | safe }}</div>
      </section>
    </section>
    <footer class="footer">
      <span>{{ code }}</span>
      <span>{{ footer_note }}</span>
    </footer>
  </main>
</body>
</html>
