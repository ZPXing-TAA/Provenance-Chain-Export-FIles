<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <title>{{ headline }}</title>
  {% include "_common_css.html.j2" %}
  <style>
    .page {
      display: grid;
      grid-template-rows: auto 1fr auto;
      gap: 24px;
    }
    header {
      border-top: 6px solid var(--ink);
      border-bottom: 2px solid var(--line);
      padding: 20px 0;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 20px;
      align-items: start;
    }
    .masthead {
      font-size: 18px;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    h1 {
      margin: 14px 0 10px;
      font-size: {{ typography.title_size }}px;
      line-height: 0.98;
      max-width: 920px;
    }
    .dek {
      color: var(--muted);
      font-size: 21px;
      max-width: 820px;
    }
    .content {
      display: grid;
      grid-template-columns: 1.4fr 0.7fr;
      gap: 24px;
      min-height: 0;
    }
    article {
      column-count: 2;
      column-gap: 28px;
      padding: 26px;
      overflow: hidden;
    }
    article p {
      margin: 0 0 14px;
    }
    aside {
      padding: 24px;
      overflow: hidden;
    }
    .side-item {
      border-bottom: 1px solid var(--line);
      padding: 14px 0;
    }
    .footer {
      color: var(--muted);
      display: flex;
      justify-content: space-between;
      font-size: 14px;
    }
  </style>
</head>
<body class="{{ body_class }}">
  <main class="page">
    <header>
      <div>
        <div class="masthead">{{ org }} Journal</div>
        <h1>{{ headline }}</h1>
        <div class="dek">{{ dek }}</div>
      </div>
      <div class="muted">{{ month }} {{ day }}, {{ year }}<br>{{ byline }}<br>{{ code }}</div>
    </header>
    <section class="content">
      <article class="card">
        {% for paragraph in paragraphs %}
        <p>{{ paragraph }}</p>
        {% endfor %}
      </article>
      <aside class="card">
        <div class="smallcaps">Related Notes</div>
        {% for item in side_items %}
        <div class="side-item">{{ item }}</div>
        {% endfor %}
        <div style="margin-top: 22px;">{{ icons[0] | safe }}</div>
      </aside>
    </section>
    <footer class="footer">
      <span>{{ city }}</span>
      <span>{{ layout_id }}</span>
    </footer>
  </main>
</body>
</html>
