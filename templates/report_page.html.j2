<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <title>{{ title }}</title>
  {% include "_common_css.html.j2" %}
  <style>
    .page {
      display: grid;
      grid-template-rows: auto auto 1fr;
      gap: 22px;
    }
    header {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 24px;
      align-items: end;
      padding-bottom: 20px;
      border-bottom: 2px solid var(--ink);
    }
    h1 {
      margin: 8px 0 0;
      font-size: {{ typography.title_size }}px;
      line-height: 1.04;
      max-width: 790px;
    }
    .docno {
      text-align: right;
      color: var(--muted);
      font-size: 14px;
    }
    .summary {
      display: grid;
      grid-template-columns: 1.1fr 0.9fr;
      gap: 22px;
    }
    .summary-text {
      padding: 26px;
      font-size: 20px;
      line-height: 1.45;
    }
    .kpis {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 14px;
    }
    .kpi {
      padding: 22px;
    }
    .kpi .value {
      font-size: 44px;
      font-weight: 800;
      color: var(--accent);
    }
    .lower {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 22px;
      min-height: 0;
    }
    .chart-panel,
    .notes {
      padding: 24px;
    }
    .chart {
      margin-top: 8px;
    }
    .notes ol {
      margin: 0;
      padding-left: 20px;
      font-size: 18px;
      line-height: 1.45;
    }
  </style>
</head>
<body>
  <main class="page">
    <header>
      <div>
        <div class="smallcaps">{{ org }} / {{ department }}</div>
        <h1>{{ title }}</h1>
      </div>
      <div class="docno">
        <div>{{ month }} {{ year }}</div>
        <div>{{ code }}</div>
      </div>
    </header>
    <section class="summary">
      <div class="card summary-text">
        {{ summary }}
      </div>
      <div class="kpis">
        {% for kpi in kpis %}
        <div class="card kpi">
          <div class="smallcaps">{{ kpi.label }}</div>
          <div class="value">{{ kpi.value }}</div>
          <div class="muted">{{ kpi.note }}</div>
        </div>
        {% endfor %}
      </div>
    </section>
    <section class="lower">
      <div class="card chart-panel">
        <div class="smallcaps">{{ chart_title }}</div>
        <div class="chart">{{ chart_svg | safe }}</div>
      </div>
      <div class="card notes">
        <div class="smallcaps">Review Notes</div>
        <ol>
          {% for note in notes %}
          <li>{{ note }}</li>
          {% endfor %}
        </ol>
      </div>
    </section>
  </main>
</body>
</html>
