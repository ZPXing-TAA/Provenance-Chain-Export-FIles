<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <title>{{ title }}</title>
  {% include "_common_css.html.j2" %}
  <style>
    .page {
      display: grid;
      grid-template-rows: auto 1fr auto;
      gap: 28px;
    }
    .hero {
      padding: 36px;
      border-radius: 8px;
      background: linear-gradient(135deg, {{ palette.accent }} 0%, {{ palette.accent2 }} 100%);
      color: white;
      min-height: 430px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }
    h1 {
      margin: 0;
      font-size: {{ typography.title_size }}px;
      line-height: 1.02;
      max-width: 850px;
    }
    .subtitle {
      margin-top: 18px;
      max-width: 760px;
      font-size: 25px;
      line-height: 1.35;
      opacity: 0.94;
    }
    .meta {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
    }
    .meta .pill {
      color: white;
      border-color: rgba(255, 255, 255, 0.48);
      background: rgba(255, 255, 255, 0.14);
    }
    .body {
      display: grid;
      grid-template-columns: 1.35fr 0.85fr;
      gap: 24px;
    }
    .items {
      padding: 28px;
    }
    .items h2,
    .side h2 {
      margin: 0 0 18px;
      font-size: 24px;
    }
    .items ul {
      margin: 0;
      padding-left: 20px;
      font-size: 22px;
      line-height: 1.55;
    }
    .side {
      padding: 28px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }
    .datebox {
      font-size: 56px;
      font-weight: 800;
      color: var(--accent);
      line-height: 1;
    }
    .footer {
      display: flex;
      justify-content: space-between;
      align-items: center;
      font-size: 16px;
      color: var(--muted);
    }
  </style>
</head>
<body>
  <main class="page">
    <section class="hero">
      <div>
        <div class="smallcaps">{{ org }}</div>
        <h1>{{ title }}</h1>
        <div class="subtitle">{{ subtitle }}</div>
      </div>
      <div class="meta">
        <span class="pill">{{ city }}</span>
        <span class="pill">{{ month }} {{ day }}</span>
        <span class="pill">{{ department }}</span>
      </div>
    </section>
    <section class="body">
      <div class="card items">
        <h2>What changes this cycle</h2>
        <ul>
          {% for item in bullets %}
          <li>{{ item }}</li>
          {% endfor %}
        </ul>
      </div>
      <aside class="card side">
        <div>
          <h2>Reference</h2>
          <p class="muted">{{ reference_text }}</p>
        </div>
        <div>
          <div class="datebox">{{ day }}</div>
          <div class="muted">{{ month }} planning window</div>
        </div>
      </aside>
    </section>
    <footer class="footer">
      <span>{{ org }}</span>
      <span>{{ code }}</span>
    </footer>
  </main>
</body>
</html>
