<svg xmlns="http://www.w3.org/2000/svg" width="{{ canvas.width }}" height="{{ canvas.height }}" viewBox="0 0 {{ canvas.width }} {{ canvas.height }}">
  {% include "_svg_common.svg.j2" %}
  <text x="{{ layout.margin }}" y="{{ layout.margin + 18 }}" class="small">{{ department }} NETWORK</text>
  <text x="{{ layout.margin }}" y="{{ layout.margin + typography.title_size + 34 }}" class="title">{{ title }}</text>
  <rect x="{{ layout.margin }}" y="{{ canvas.height * 0.22 }}" width="{{ canvas.width - layout.margin * 2 }}" height="{{ canvas.height * 0.62 }}" rx="24" class="panel"/>
  {% for edge in edges %}
  <line x1="{{ edge.x1 }}" y1="{{ edge.y1 }}" x2="{{ edge.x2 }}" y2="{{ edge.y2 }}" stroke="{{ palette.accent2 }}" stroke-width="5" stroke-linecap="round" opacity="0.72"/>
  {% endfor %}
  {% for node in nodes %}
  <g>
    <circle cx="{{ node.x }}" cy="{{ node.y }}" r="{{ node.r + 9 }}" fill="{{ palette.panel }}" stroke="{{ palette.line }}" stroke-width="2"/>
    <circle cx="{{ node.x }}" cy="{{ node.y }}" r="{{ node.r }}" fill="{{ palette.accent }}"/>
    <text x="{{ node.x + 16 }}" y="{{ node.y - 8 }}" class="muted">{{ node.label }}</text>
  </g>
  {% endfor %}
  <text x="{{ layout.margin + 22 }}" y="{{ canvas.height * 0.84 - 28 }}" class="muted">{{ city }} route map / {{ code }}</text>
</svg>
